# Blaze Event Hub — local environment example.
# Never commit a real .env file.
# The client secret stays only in the backend.
# Refresh tokens and access tokens stay only in secure backend storage.
# Browser/frontend code must never receive BLAZE_CLIENT_SECRET.

BLAZE_CLIENT_ID=<public_client_id>
BLAZE_CLIENT_SECRET=<placeholder_apenas_backend>
BLAZE_REDIRECT_URI=http://localhost:8080/api/blaze/oauth/callback
BLAZE_AUTH_BASE_URL=https://blaze.stream
BLAZE_API_BASE_URL=https://api.blaze.stream
BLAZE_SOCKET_URL=https://blaze.stream
BLAZE_SOCKET_PATH=/ws
BLAZE_SCOPES=users.read,offline.access
BLAZE_MONITORED_CHANNEL_ID=<optional_channel_uuid>
EVENTHUB_API_KEY=dev-local-key
EVENTHUB_DB_URL=jdbc:h2:file:./data/eventhub-dev;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;AUTO_SERVER=TRUE
EVENTHUB_DB_USER=sa
EVENTHUB_DB_PASSWORD=
